# ── CONFIGURAÇÕES DO SERVIDOR ────────────────────────────────────
PORT=3000

# ── BANCO DE DADOS (HOSTINGER / POSTGRESQL) ──────────────────────
# Se estiver testando local, use o endereço do seu banco local.
# Na Hostinger, substitua pelos dados do painel do banco.
# Depois (Ajustado para seu PC):
DATABASE_URL=postgresql://postgres:1234@127.0.0.1:5432/aline_advogada

# ── CRIPTOGRAFIA (AES-256-GCM) ──────────────────────────────────
# MUITO IMPORTANTE: Essa chave precisa ter exatamente 64 caracteres hexadecimais.
# GERE UMA NOVA NO TERMINAL COM: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=7b397a2453a88cb197603016d4b13e231c0270cf235824b97d17449c36b70f13

# ── CLOUDFLARE R2 (STORAGE DE ARQUIVOS) ─────────────────────────
R2_ACCOUNT_ID=seu_account_id_do_painel_cloudflare
R2_ACCESS_KEY_ID=sua_access_key
R2_SECRET_ACCESS_KEY=sua_secret_key
R2_BUCKET_NAME=nome-do-seu-bucket-juridico

# ── EVOLUTION API (WHATSAPP) ────────────────────────────────────
EVOLUTION_API_URL=https://sua-api-evolution.com
EVOLUTION_API_KEY=sua_api_key_gerada_na_api
EVOLUTION_INSTANCE=nome_da_instancia_whatsapp

# ── GOOGLE CALENDAR OAUTH2 ───────────────────────────────────────
GOOGLE_CLIENT_ID=seu_id_cliente.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_secret_cliente
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback